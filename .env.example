# OpenAI-compatible LLM endpoint for summaries
LLM_BASE_URL=http://100.118.185.95:1234/v1
LLM_API_KEY=1
LLM_MODEL=qwen/qwen3.5-9b

# Server
PORT=788
HOST=0.0.0.0

# STT tuning
STT_DEVICE=cuda            # cuda | cpu
STT_NCPU=4
SPK_SIM_THRESHOLD=0.55     # lower = more sensitive (more speaker splits)
STREAM_CHUNK_MS=600        # streaming model chunk size (model trained on 600ms)
VAD_SILENCE_MS=500         # silence to finalize an utterance
MAX_UTTERANCE_MS=15000     # force-finalize after this even without silence
